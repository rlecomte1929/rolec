# Frontend (Vite) — must be prefixed with VITE_
VITE_API_URL=http://localhost:8000
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Backend (FastAPI) — set in your shell or Render env vars
# DATABASE_URL — defaults to sqlite:///./relopass.db if unset
# For Supabase Postgres: postgresql://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///./relopass.db

# Policy document uploads (HR Policy page) — required for PDF/DOCX upload and storage
# Supabase Dashboard → your project → Settings → API (or Integrations → API Keys):
#   - Project URL → SUPABASE_URL (e.g. https://xxxxx.supabase.co)
#   - For the Python backend you must use the LEGACY keys: open the tab
#     "Legacy anon, service_role API keys" and copy the "service_role" key (long JWT starting with eyJ...).
#     The new "Secret keys" (sb_secret_...) are not yet supported by supabase-py.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Set to 1 to skip creating Supabase Auth users on login/register (not recommended in prod)
# DISABLE_SUPABASE_AUTH_SYNC=0

# Postgres only — SQLAlchemy pool (optional; defaults are safe for Supabase)
# SQLALCHEMY_POOL_SIZE=5
# SQLALCHEMY_MAX_OVERFLOW=10
# SQLALCHEMY_POOL_RECYCLE=280

# CORS — comma-separated origins (extends built-in defaults)
# Backend already allows localhost:3000–3005 and 5173; add more if needed
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:3002
# Optional override; default regex matches https://relopass.com and https://*.relopass.com
# CORS_ORIGIN_REGEX=^https://([\w-]+\.)*relopass\.com$

# PORT — Render injects this automatically; fallback to 8000 locally
# PORT=8000
